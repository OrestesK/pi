{
  "mcpServers": {
    "context7": {
      "command": "context7-mcp",
      "args": [],
      "lifecycle": "lazy"
    },
    "tree-sitter": {
      "command": "bash",
      "args": [
        "-lc",
        "exec node \"${PI_CONFIG_DIR:-/opt/orestes-pi-config}/mcp-servers/tree-sitter/index.mjs\""
      ],
      "directTools": [
        "search_symbols",
        "document_symbols",
        "symbol_definition",
        "pattern_search",
        "codebase_overview",
        "codebase_map"
      ],
      "lifecycle": "keep-alive"
    },
    "context-mode": {
      "command": "context-mode",
      "lifecycle": "lazy"
    }
  }
}
