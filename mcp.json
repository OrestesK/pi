{
  "mcpServers": {
    "context7": {
      "url": "https://mcp.context7.com/mcp/oauth",
      "auth": "oauth",
      "lifecycle": "lazy"
    },
    "context-mode": {
      "command": "bash",
      "args": [
        "-lc",
        "exec node \"${PI_CODING_AGENT_DIR:-$HOME/.pi/agent}/packages/context-mode/cli.bundle.mjs\""
      ],
      "lifecycle": "lazy"
    },
    "sentry": {
      "url": "https://mcp.sentry.dev/mcp",
      "auth": "oauth",
      "lifecycle": "lazy"
    },
    "descope": {
      "url": "https://mcp.descope.com",
      "auth": "oauth",
      "lifecycle": "lazy"
    },
    "notion": {
      "url": "https://mcp.notion.com/mcp",
      "lifecycle": "lazy"
    },
    "google_docs": {
      "command": "bash",
      "args": [
        "-lc",
        "set -e; set -a; source \"${PI_CODING_AGENT_DIR:-$HOME/.pi/agent}/mcp-oauth/google_docs/env.sh\"; set +a; export npm_config_ignore_scripts=true; exec npx -y @a-bonus/google-docs-mcp@1.10.0"
      ],
      "lifecycle": "lazy"
    },
    "slack": {
      "command": "bash",
      "args": [
        "-lc",
        "set -e; set -a; source \"${PI_CODING_AGENT_DIR:-$HOME/.pi/agent}/mcp-oauth/slack/env.sh\"; set +a; exec \"${PI_SLACK_MCP_SERVER_BIN:-$HOME/.local/bin/slack-mcp-server-patched}\" --transport stdio"
      ],
      "lifecycle": "lazy"
    },
    "retool": {
      "url": "https://valsai.retool.com/mcp",
      "lifecycle": "lazy"
    },
    "excalidraw-local": {
      "command": "pnpm",
      "args": [
        "dlx",
        "mcp-excalidraw-server@1.1.0"
      ],
      "lifecycle": "lazy"
    },
    "docent": {
      "command": "uv",
      "args": [
        "tool",
        "run",
        "--from",
        "docent-python>=0.1.74",
        "docent-mcp"
      ],
      "lifecycle": "lazy"
    }
  }
}
