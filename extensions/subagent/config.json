{
  "waitTool": false,
  "toolDescriptionMode": "compact",
  "toolExtensions": {
    "mcp": {
      "description": "Regular MCP access for research roles",
      "builtinTools": ["mcp"],
      "allowedAgents": ["scout", "researcher", "context-builder"]
    }
  },
  "asyncByDefault": true,
  "forceTopLevelAsync": true,
  "maxSubagentDepth": 32,
  "maxSubagentSpawnsPerSession": 20000,
  "globalConcurrencyLimit": 100,
  "chain": {
    "dynamicFanout": {
      "maxItems": 20000
    }
  },
  "scheduledRuns": {
    "enabled": true,
    "maxPending": 20000,
    "maxLatenessMs": 1209600000
  },
  "control": {
    "enabled": true,
    "needsAttentionAfterMs": 60000,
    "activeNoticeAfterMs": 120000,
    "failedToolAttemptsBeforeAttention": 3,
    "notifyOn": ["active_long_running", "needs_attention"],
    "notifyChannels": ["event", "async"]
  },
  "intercomBridge": {
    "mode": "always"
  },
  "parallel": {
    "maxTasks": 20000,
    "concurrency": 20
  },
  "progress": {
    "reportMode": "supervisor"
  }
}
