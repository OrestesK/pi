{
  "$schema": "https://unpkg.com/@aliou/pi-guardrails@0.15.0/schema.json",
  "features": {
    "policies": true,
    "permissionGate": true,
    "pathAccess": false
  },
  "permissionGate": {
    "patterns": [
      {
        "pattern": "rm -rf",
        "description": "recursive force delete"
      },
      {
        "pattern": "sudo",
        "description": "superuser command"
      },
      {
        "pattern": "dd of=",
        "description": "disk write operation"
      },
      {
        "pattern": "mkfs.",
        "description": "filesystem format"
      },
      {
        "pattern": "chmod -R 777",
        "description": "insecure recursive permissions"
      },
      {
        "pattern": "chown -R",
        "description": "recursive ownership change"
      },
      {
        "pattern": "doas",
        "description": "privileged command execution"
      },
      {
        "pattern": "pkexec",
        "description": "privileged command execution"
      },
      {
        "pattern": "shred",
        "description": "secure file overwrite"
      },
      {
        "pattern": "wipefs",
        "description": "filesystem signature wipe"
      },
      {
        "pattern": "blkdiscard",
        "description": "block device discard"
      },
      {
        "pattern": "fdisk",
        "description": "disk partitioning"
      },
      {
        "pattern": "parted",
        "description": "disk partitioning"
      },
      {
        "pattern": "docker run --privileged",
        "description": "container with privileged mode"
      },
      {
        "pattern": "(?:^|[;&|()])\\s*(?:(?:(?:env\\s+(?:(?:-[A-Za-z]+|--[A-Za-z0-9-]+(?:=\\S+)?|\\S+=\\S+)\\s+)*)|(?:command\\s+)))*(?:(?:/usr)?/bin/|/usr/local/bin/)?git\\b(?:\\s+(?:(?:-C|-c|--git-dir|--work-tree|--namespace)\\s+\\S+|(?:--git-dir|--work-tree|--namespace)=\\S+|-[A-Za-z]+|--[A-Za-z0-9-]+))*\\s+(?:add|am|apply|bisect|branch|checkout|cherry-pick|clean|clone|commit|fetch|init|merge|mv|pull|push|rebase|reflog|remote|reset|restore|revert|rm|stash|submodule|switch|tag|worktree)\\b",
        "regex": true,
        "description": "Git repository mutation"
      },
      {
        "pattern": "(?:^|[;&|()])\\s*(?:(?:(?:env\\s+(?:(?:-[A-Za-z]+|--[A-Za-z0-9-]+(?:=\\S+)?|\\S+=\\S+)\\s+)*)|(?:command\\s+)))*(?:(?:/usr)?/bin/|/usr/local/bin/)?git\\b(?:\\s+(?:(?:-C|-c|--git-dir|--work-tree|--namespace)\\s+\\S+|(?:--git-dir|--work-tree|--namespace)=\\S+|-[A-Za-z]+|--[A-Za-z0-9-]+))*\\s+(?:config\\b(?=(?:(?![;&|()]).)*?(?:\\s(?:--add|--replace-all|--unset(?:-all)?|--rename-section|--remove-section)\\b|\\s+[A-Za-z0-9_][A-Za-z0-9_.-]*\\s+\\S+))(?![^;&|()]*\\s(?:--get|--get-all|--get-regexp|--list|-l)\\b)|notes\\s+(?:add|append|copy|edit|merge|prune|remove)\\b|credential\\s+(?:approve|reject)\\b)",
        "regex": true,
        "description": "Git metadata or credential mutation"
      },
      {
        "pattern": "(?:^|[;&|()])\\s*(?:(?:(?:env\\s+(?:(?:-[A-Za-z]+|--[A-Za-z0-9-]+(?:=\\S+)?|\\S+=\\S+)\\s+)*)|(?:command\\s+)))*(?:(?:/usr)?/bin/|/usr/local/bin/)?git\\b(?:\\s+(?:(?:-C|-c|--git-dir|--work-tree|--namespace)\\s+\\S+|(?:--git-dir|--work-tree|--namespace)=\\S+|-[A-Za-z]+|--[A-Za-z0-9-]+))*\\s+push\\b[^;&|()]*(?:--force|-f)\\b",
        "regex": true,
        "description": "Git force push"
      },
      {
        "pattern": "(^|[;&|()\\s])gs\\s+(?:(?:upstack|downstack|branch|stack|repo|commit)\\s+)?(?:absorb|amend|checkout|continue|create|delete|onto|rename|rebase|restack|submit|sync)\\b",
        "regex": true,
        "description": "git-spice repository mutation"
      }
    ],
    "allowedPatterns": [
      {
        "pattern": "^[\\t ]*(?:(?:/usr)?/bin/|/usr/local/bin/)?git[\\t ]+(?:branch(?:[\\t ]+(?:-a|--all|-r|--remotes|-v|-vv|--verbose|--no-abbrev|--show-current|--no-color|--color=never))*|tag(?:[\\t ]+(?:-l|--list|--no-column|--color=never))*|remote(?:[\\t ]+(?:-v|--verbose))?|worktree[\\t ]+list(?:[\\t ]+(?:--porcelain|-z))*|submodule(?:[\\t ]+status(?:[\\t ]+(?:--cached|--recursive))*|[\\t ]+summary)?|stash[\\t ]+(?:list|show)|reflog(?:[\\t ]+show(?:[\\t ]+--all)?)?|bisect[\\t ]+(?:log|terms))[\\t ]*$",
        "regex": true,
        "description": "Known read-only Git inspection"
      },
      {
        "pattern": "^[\\t ]*(?:(?:/usr)?/bin/|/usr/local/bin/)?git[\\t ]+(?:add[\\t ]+(?:-n|--dry-run)|apply[\\t ]+(?:--check|--stat|--numstat|--summary)|clean(?:[\\t ]+(?:-d|-x|-X))*[\\t ]+(?:-n|--dry-run)(?:[\\t ]+(?:-d|-x|-X))*|commit[\\t ]+--dry-run|fetch[\\t ]+--dry-run|push[\\t ]+(?:-n|--dry-run)|reflog[\\t ]+expire[\\t ]+--dry-run[\\t ]+--all|worktree[\\t ]+prune[\\t ]+--dry-run)[\\t ]*$",
        "regex": true,
        "description": "Known no-write Git mode"
      }
    ],
    "autoDenyPatterns": [
      {
        "pattern": "(?:^|[;&|()])\\s*rm\\b(?=[^;&|()]*\\s(?:-[A-Za-z]*[rR][A-Za-z]*|--recursive)\\b)(?=[^;&|()]*\\s(?:-[A-Za-z]*[fF][A-Za-z]*|--force)\\b)[^;&|()]*\\s(?:--\\s+)?(?:/|~/?|\\./?)(?=\\s|$|[;&|()])",
        "regex": true
      },
      {
        "pattern": ":(){ :|:& };:"
      },
      {
        "pattern": "(^|[;&|()\\s])dd\\s+.*\\bof=/dev/",
        "regex": true
      },
      {
        "pattern": "mkfs"
      },
      {
        "pattern": "(^|[;&|()\\s])sudo\\b",
        "regex": true
      },
      {
        "pattern": "chmod 777"
      },
      {
        "pattern": "(^|[;&|()\\s])(?:curl|wget)\\b[^|;]*\\|\\s*(?:(?:/usr)?/bin/|/usr/local/bin/)?(?:bash|sh)\\b",
        "regex": true
      },
      {
        "pattern": "(^|[;&|()\\s])(?:(?:/usr)?/bin/|/usr/local/bin/)?(?:bash|sh)\\s+<\\(\\s*(?:curl|wget)\\b",
        "regex": true
      }
    ]
  },
  "policies": {
    "rules": [
      {
        "id": "no-env-files",
        "patterns": [
          {
            "pattern": "**/.env"
          },
          {
            "pattern": "**/.env.*"
          },
          {
            "pattern": "**/credentials*"
          },
          {
            "pattern": "**/secrets*"
          }
        ],
        "protection": "readOnly",
        "enabled": true
      },
      {
        "id": "no-pi-auth-material",
        "patterns": [
          {
            "pattern": "auth.json"
          },
          {
            "pattern": "mcp-oauth/**"
          }
        ],
        "protection": "noAccess",
        "enabled": true
      },
      {
        "id": "no-git-internals",
        "patterns": [
          {
            "pattern": "**/.git/**"
          }
        ],
        "protection": "noAccess",
        "enabled": true
      }
    ]
  },
  "version": "0.9.0-20260327",
  "applyBuiltinDefaults": true,
  "onboarding": {
    "completed": true,
    "completedAt": "2026-05-03T00:00:00.000Z",
    "version": "0.9.0-20260327"
  }
}
