{
  "name": "pi-codex-retry",
  "version": "0.1.0",
  "description": "Pi extension that retries recoverable OpenAI Codex WebSocket transport failures while preserving streaming.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "codex",
    "websocket",
    "retry"
  ],
  "files": [
    "src/",
    "tests/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm test && npm run typecheck"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@earendil-works/pi-ai": "^0.80.3"
  }
}
