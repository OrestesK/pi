{
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.6-sol",
  "defaultThinkingLevel": "max",
  "theme": "gruvbox-custom",
  "quietStartup": true,
  "defaultProjectTrust": "always",
  "steeringMode": "all",
  "followUpMode": "all",
  "collapseChangelog": true,
  "enableInstallTelemetry": false,
  "npmCommand": [
    "sh",
    "-lc",
    "npm --prefix \"$HOME/.npm-global\" \"$@\"",
    "npm"
  ],
  "branchSummary": {
    "skipPrompt": true
  },
  "hideThinkingBlock": true,
  "terminal": {
    "showImages": true,
    "imageWidthCells": 80,
    "showTerminalProgress": true
  },
  "editorPaddingX": 0,
  "outputPad": 0,
  "retry": {
    "maxRetries": 3,
    "baseDelayMs": 2000
  },
  "lastChangelogVersion": "0.80.6",
  "transport": "auto",
  "compaction": {
    "enabled": true,
    "reserveTokens": 24000,
    "keepRecentTokens": 20000
  },
  "slipstreamCompact": {
    "enabled": true,
    "autoTrigger": true,
    "triggerContextPercent": 0.6,
    "slipstreamKeepRecentTokens": 50000,
    "summaryModel": "openai-codex/gpt-5.6-terra",
    "judgeModel": "openai-codex/gpt-5.6-sol",
    "judgeThreshold": 7,
    "repairAttempts": 3,
    "rejectedSummaryMode": "ask",
    "pendingTtlMs": 300000,
    "artifactRoot": ".scratch/compactions"
  },
  "pi-memory-md": {
    "enabled": true,
    "memoryDir": {
      "localPath": "~/.pi/memory-md"
    },
    "delivery": "message-append",
    "hooks": {
      "sessionStart": [],
      "sessionEnd": [],
      "beforeAgentStart": [
        "sessionBridge"
      ]
    },
    "tape": {
      "enabled": true,
      "onlyGit": false,
      "thread": true
    }
  },
  "packages": [
    "extensions/claude-ui",
    "git:github.com/nicobailon/pi-intercom@e234a4446e2b3f9c13a1ec3151ae2169315c810f",
    {
      "source": "git:github.com/aws/agent-toolkit-for-aws@fae975d565b6c1752e3f4795c499fb3951039777",
      "extensions": [],
      "skills": [
        "skills/core-skills/**",
        "skills/specialized-skills/operations-skills/troubleshooting-application-failures"
      ],
      "prompts": [],
      "themes": []
    },
    "packages/pi-subagents",
    "npm:pi-mcp-adapter",
    {
      "source": "packages/pi-lens",
      "skills": [
        "ast-grep"
      ]
    },
    "npm:pi-web-access",
    "packages/pi-memory-md",
    "npm:@aliou/pi-guardrails",
    {
      "source": "npm:pi-ask-user",
      "skills": []
    },
    "packages/pi-tool-result-virtualizer",
    {
      "source": "packages/context-mode",
      "skills": [
        "context-mode",
        "ctx-doctor"
      ]
    },
    "packages/pi-slipstream-compact",
    "packages/pi-goal-supervisor",
    "packages/pisesh",
    "npm:pi-btw",
    "packages/pi-openai-service-tier",
    "packages/pi-sixel",
    "npm:@carter-mcalister/pi-codex-image-gen@0.2.0"
  ],
  "pi-sixel": {
    "maxColumns": 120,
    "maxRows": 36,
    "quality": "high"
  },
  "subagents": {
    "defaultModel": "openai-codex/gpt-5.6-terra",
    "disableBuiltins": false
  },
  "autocompleteMaxVisible": 10,
  "doubleEscapeAction": "tree",
  "treeFilterMode": "no-tools",
  "httpIdleTimeoutMs": 3600000
}