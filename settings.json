{
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "high",
  "quietStartup": true,
  "steeringMode": "all",
  "followUpMode": "all",
  "collapseChangelog": true,
  "enableInstallTelemetry": false,
  "branchSummary": {
    "skipPrompt": true
  },
  "hideThinkingBlock": true,
  "retry": {
    "maxRetries": 3,
    "baseDelayMs": 2000
  },
  "transport": "auto",
  "compaction": {
    "enabled": true,
    "reserveTokens": 24000,
    "keepRecentTokens": 20000
  },
  "slipstreamCompact": {
    "enabled": true,
    "autoTrigger": true,
    "triggerContextPercent": 0.6,
    "slipstreamKeepRecentTokens": 50000,
    "compactionStrategy": "direct",
    "summaryModel": "openai-codex/gpt-5.5",
    "judgeModel": "openai-codex/gpt-5.5",
    "judgeThreshold": 7,
    "repairAttempts": 3,
    "rejectedSummaryMode": "accept",
    "pendingTtlMs": 300000,
    "artifactRoot": ".scratch/compactions"
  },
  "packages": [
    "packages/pi-subagents",
    "npm:pi-mcp-adapter",
    {
      "source": "npm:pi-lens",
      "skills": [
        "ast-grep"
      ]
    },
    "npm:pi-web-access",
    {
      "source": "packages/context-mode",
      "skills": [
        "context-mode",
        "ctx-doctor"
      ]
    },
    "npm:pi-slipstream-compact",
    "packages/pi-goal-supervisor"
  ],
  "subagents": {
    "disableBuiltins": false
  },
  "autocompleteMaxVisible": 10
}
