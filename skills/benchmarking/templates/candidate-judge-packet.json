{
  "packet_id": "<candidate-judge-packet-id>",
  "packet_schema_version": "candidate-judge-packet-v2",
  "created_at": "2026-07-09",
  "suite_id": "<suite-id>",
  "run_id": "<run-id>",
  "task_id": "<task-id>",
  "review_mode": "gold_reference_single_output",
  "visibility": "judge_private",
  "primary_metric": "adjudicated_llm_judge_pr_quality",
  "rubric": {
    "general_rubric_ref": "benchmarking:references/pr-quality-llm-judge-rubric.md",
    "general_rubric_version": "pr-quality-llm-judge-v2",
    "task_supplement_ref": "task:private/per_task_rubric_supplement.json",
    "reviewer_prompt_version": "candidate-gold-reference-judge-prompt-v2"
  },
  "task": {
    "task_statement_ref": "task:public/task.md",
    "setup_notes_ref": "task:public/setup-notes.md",
    "evaluator_brief_ref": "task:private/evaluator-brief.md",
    "base_commit": "<base-commit>",
    "source_commit": "<source-commit>",
    "source_pr": "<source-pr-or-null>",
    "source_repo_logical_ref": "<source-repo:repo-name>"
  },
  "gold_reference": {
    "allowed_for_candidate": false,
    "allowed_for_judge": true,
    "raw_gold_diff_included": false,
    "gold_diff_ref": "private:<gold-diff-ref-or-command>",
    "reference_summary_ref": "task:private/per_task_rubric_supplement.json",
    "privacy_note": "Do not expose raw gold/reference material in candidate-facing packets or normal public reports."
  },
  "candidate": {
    "candidate_label": "X",
    "candidate_identity_visible_to_judge": false,
    "candidate_artifact_id": "<opaque-candidate-artifact-id>",
    "candidate_diff_ref": "suite:runs/<run-id>/reports/<score-prefix>-<task-id>/diffs/implementation.diff",
    "final_answer_ref": "suite:runs/<run-id>/candidates/<task-id>/final-answer.md",
    "candidate_snapshot_ref": "suite:runs/<run-id>/reports/<score-prefix>-candidate-snapshots/<task-id>",
    "transcript_or_process_summary_ref": null
  },
  "review_controls": {
    "judge_gold_as_intent_reference_not_patch_shape": true,
    "accept_clean_equivalent_implementations": true,
    "require_task_rubric_sufficiency_classification": true,
    "require_expectation_source_on_rejection_findings": true,
    "expectation_source_categories": [
      "public_task_stated",
      "task_specific_outcome_rubric",
      "repo_discoverable",
      "gold_reference_intent",
      "not_applicable"
    ],
    "reject_shape_biased_counted_findings": true,
    "secondary_score_0_to_10": {
      "enabled": true,
      "aggregation": "median/range only; do not average raw scores"
    }
  },
  "judge_panel": {
    "default_topology_profile": "quality_gate_3",
    "judge_count_target": 3,
    "leaf_output_template": "benchmarking:templates/candidate-output-review.json",
    "adjudication_template": "benchmarking:templates/candidate-review-adjudication.json",
    "independence_required": true,
    "adjudication_required": true
  },
  "allowed_evidence_scope": {
    "normal_judge": [
      "task statement",
      "general rubric",
      "task rubric supplement",
      "gold/reference summary or diff",
      "candidate diff",
      "candidate final answer",
      "process and verification summaries when available"
    ],
    "public_report": [
      "adjudicated verdict",
      "evidence summaries",
      "process diagnostics",
      "missing evidence"
    ]
  },
  "privacy_checks": {
    "candidate_packet_contains_gold": false,
    "public_report_contains_raw_gold": false,
    "raw_host_paths_publishable": false
  },
  "missing_evidence": []
}
